server {
    listen 4000 ssl;
    listen [::]:4000 ssl;
    server_name __VOICE_EDGE_SAN_HOST__;

    ssl_certificate     __SSL_CERT__;
    ssl_certificate_key __SSL_KEY__;
    ssl_protocols TLSv1.2 TLSv1.3;

    root /opt/voice-edge/public;
    index index.html;

    # SPA fallback
    location / {
        try_files $uri $uri/ /index.html;
    }

    # API reverse proxy to backend (China east)
    location /api/ {
        proxy_pass https://__BACKEND_HOST__:3000;
        proxy_ssl_verify off;          # backend uses self-signed cert
        proxy_ssl_server_name on;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 300s;
    }

    # WebSocket reverse proxy (Upgrade headers)
    location /ws {
        proxy_pass https://__BACKEND_HOST__:3000;
        proxy_ssl_verify off;
        proxy_ssl_server_name on;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 7d;         # long-lived connection
        proxy_send_timeout 7d;
    }
}
