# Deployment target (do NOT commit real values; copy to .env)
VOICE_HOST=<public IP or hostname of target server>
VOICE_SSH_USER=<SSH login user>
VOICE_SSH_KEY=<absolute path to SSH private key (.pem)>

# ---- Edge node (US) ----
VOICE_EDGE_HOST=<US public IP or hostname>
VOICE_EDGE_SSH_USER=<SSH login user>
VOICE_EDGE_SSH_KEY=<absolute path to SSH private key>
